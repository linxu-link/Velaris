    <!-- Seed Data - Noises -->
    <string name="seed_noise_rain_title">Rain</string>
    <string name="seed_noise_rain_description">Fine raindrops fall continuously, suitable for reading, daydreaming and slow-paced work</string>
    <string name="seed_noise_rain_heavy_title">Heavy Rain</string>
    <string name="seed_noise_rain_heavy_description">Thicker rain curtain wraps the space, stronger immersion, easier to block out noise</string>
    <string name="seed_noise_fireplace_title">Fireplace</string>
    <string name="seed_noise_fireplace_description">Crackling of slowly burning wood adds stable warmth to the scene</string>
    <string name="seed_noise_wind_title">Wind</string>
    <string name="seed_noise_wind_description">Wind passing through forest gaps from afar, light presence but opens up the space</string>
    <string name="seed_noise_ocean_title">Ocean Waves</string>
    <string name="seed_noise_ocean_description">Tides push in and recede layer by layer, loose rhythm, good for emptying the mind</string>
    <string name="seed_noise_piano_title">Piano</string>
    <string name="seed_noise_piano_description">Low-saturation piano lines only as background, without stealing attention</string>
    <string name="seed_noise_thunder_title">Thunder</string>
    <string name="seed_noise_thunder_description">Distant thunder occasionally rolls by, adding depth to the night</string>
    <string name="seed_noise_thunder_and_rain_title">Thunderstorm</string>
    <string name="seed_noise_thunder_and_rain_description">Thunder and rain curtain layered, overall atmosphere more enclosed and quiet</string>
    <string name="seed_noise_seagull_title">Seagulls</string>
    <string name="seed_noise_seagull_description">Sea surface retains openness, occasional seagull calls, not too dense</string>
    <string name="seed_noise_river_title">River</string>
    <string name="seed_noise_river_description">Water flows along stone surface, uniform frequency, suitable for long-term companionship</string>
    <string name="seed_noise_insects_title">Insects</string>
    <string name="seed_noise_insects_description">Thin and continuous insect sounds push the scene toward a quieter night texture</string>
    <string name="seed_noise_wind_chime_title">Wind Chimes</string>
    <string name="seed_noise_wind_chime_description">Chimes appear infrequently, leaving more blank space, suitable as decorative layer</string>
    <string name="seed_noise_page_turn_title">Page Turn</string>
    <string name="seed_noise_page_turn_description">Page turn sound is light and short, suitable with study or reading scenes</string>
    <string name="seed_noise_flip_clock_title">Flip Clock</string>
    <string name="seed_noise_flip_clock_description">Mechanical page flip sound repeats at fixed rhythm, suitable for focus scenes needing time sense</string>
    <string name="seed_noise_typing_title">Typing</string>
    <string name="seed_noise_typing_description">Key press feedback clear but frequency band restrained, suitable for workspace atmosphere</string>
    <string name="seed_noise_writing_title">Writing</string>
    <string name="seed_noise_writing_description">Pen tip on paper friction is light, suitable for low-presence companionship</string>
    <string name="seed_noise_train_title">Train</string>
    <string name="seed_noise_train_description">Continuous and monotonous rolling sound, very suitable for nighttime relaxation or sleep</string>

