# EditorConfig - Velaris
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
indent_style = space
indent_size = 4
max_line_length = off
# Disable max-line-length rule (Compose + Chinese comments commonly exceed; keep other formatting)
ktlint_standard_max-line-length = disabled
# Allow standard Compose naming (PascalCase for Composable UI functions)
ktlint_function_naming_ignore_when_annotated_with = Composable

[*.xml]
indent_style = space
indent_size = 4

[*.{md,mdx}]
trim_trailing_whitespace = false
max_line_length = off

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
